{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Exclusive fabrics for sale or bespoke tailoring."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "price_per_meter": {
      "type": "decimal",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "fabric_type": {
      "type": "string"
    },
    "work": {
      "type": "string"
    },
    "width_inches": {
      "type": "integer"
    },
    "care_instructions": {
      "type": "string"
    },
    "is_sold_out": {
      "type": "boolean",
      "default": false
    },
    "eligible_for_bespoke": {
      "type": "boolean",
      "default": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos"]
    }
  }
}
